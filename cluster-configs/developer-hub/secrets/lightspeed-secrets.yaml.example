# Lightspeed LLM Provider Secrets
#
# To use:
# 1. Copy this file to lightspeed-secrets.yaml (it's gitignored)
# 2. Fill in your configuration
# 3. Apply with: oc apply -f lightspeed-secrets.yaml
#
# Only set ENABLE_* for the provider you want to use.
# To disable a provider, leave the ENABLE_* key UNSET (not "false").
apiVersion: v1
kind: Secret
metadata:
  name: lightspeed-auth-secrets
  namespace: rhdh
type: Opaque
stringData:
  # --- vLLM (OpenAI-compatible) ---
  # ENABLE_VLLM: "true"
  # VLLM_URL: "https://<api_endpoint>/v1"
  # VLLM_API_KEY: "<api_key>"

  # --- OpenAI ---
  # ENABLE_OPENAI: "true"
  # OPENAI_API_KEY: "<api_key>"

  # --- Ollama ---
  # ENABLE_OLLAMA: "true"
  # OLLAMA_URL: "http://<ollama_endpoint>"

  # --- Vertex AI (Gemini) ---
  # ENABLE_VERTEX_AI: "true"
  # VERTEX_AI_PROJECT: "<gcp-project-id>"
  # VERTEX_AI_LOCATION: "<region>"
  # GOOGLE_APPLICATION_CREDENTIALS: "/app-root/gcp-sa-key.json"
  # Note: Also mount the SA key JSON via a separate secret in the Backstage CR.
